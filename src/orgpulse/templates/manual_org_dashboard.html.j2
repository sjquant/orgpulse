<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ overview.org }} productivity leaderboard</title>
  <style>
    :root {
      color-scheme: dark;
      --bg: #070b12;
      --panel: #0d1320;
      --panel-2: #101827;
      --line: #1d2738;
      --line-strong: #2b3952;
      --text: #e8edf7;
      --muted: #8ea0bf;
      --accent: #75c7ff;
      --accent-2: #7ee0b3;
      --accent-3: #f0b35f;
      --danger: #ff8b8b;
      --positive: #7ee0b3;
      --negative: #ff8b8b;
      --shadow: 0 10px 30px rgba(0, 0, 0, 0.28);
    }

    * { box-sizing: border-box; }

    html, body {
      margin: 0;
      min-height: 100%;
      background:
        linear-gradient(180deg, rgba(117, 199, 255, 0.05), transparent 220px),
        linear-gradient(180deg, #060910 0%, var(--bg) 100%);
      color: var(--text);
      font-family: "IBM Plex Sans", "Helvetica Neue", sans-serif;
    }

    body { padding: 24px 20px 36px; }

    .shell {
      max-width: 1440px;
      margin: 0 auto;
    }

    .hero {
      display: grid;
      gap: 16px;
      align-items: start;
      margin-bottom: 16px;
    }

    .panel {
      background: linear-gradient(180deg, rgba(16, 24, 39, 0.96), rgba(10, 16, 28, 0.98));
      border: 1px solid var(--line);
      border-radius: 8px;
      box-shadow: var(--shadow);
      min-width: 0;
    }

    .hero-panel,
    .insight-panel,
    .section-panel {
      padding: 18px 20px;
    }

    .eyebrow,
    .section-kicker {
      margin: 0 0 10px;
      color: var(--accent);
      font-size: 0.72rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      font-weight: 700;
    }

    h1, h2, h3, p { margin-top: 0; }

    h1 {
      margin-bottom: 10px;
      font-size: clamp(2rem, 2.8vw, 3.3rem);
      line-height: 0.98;
      letter-spacing: -0.03em;
      font-family: "Space Grotesk", "IBM Plex Sans", sans-serif;
    }

    h2 {
      margin-bottom: 8px;
      font-size: 1.05rem;
      letter-spacing: -0.01em;
    }

    .subtitle,
    .section-copy,
    .insight-card p,
    .table-footnote {
      color: var(--muted);
      line-height: 1.55;
    }

    .hero-meta {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
      margin-top: 16px;
    }

    .meta-box,
    .stat-card {
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid var(--line);
      border-radius: 6px;
      padding: 12px 14px;
    }

    .meta-label,
    .stat-label {
      display: block;
      margin-bottom: 6px;
      color: var(--muted);
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      font-weight: 700;
    }

    .meta-value {
      font-size: 0.95rem;
      font-weight: 700;
      overflow-wrap: anywhere;
    }

    .primary-readout {
      margin-top: 16px;
      padding: 14px;
      border: 1px solid rgba(117, 199, 255, 0.28);
      border-left: 3px solid var(--accent);
      border-radius: 6px;
      background: rgba(117, 199, 255, 0.06);
    }

    .primary-readout h2 {
      margin-bottom: 6px;
      font-size: 0.95rem;
    }

    .section-nav {
      position: sticky;
      top: 0;
      z-index: 5;
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 16px;
      padding: 10px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: rgba(7, 11, 18, 0.9);
      backdrop-filter: blur(14px);
    }

    .section-nav a {
      color: var(--muted);
      text-decoration: none;
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 7px 10px;
      font-size: 0.82rem;
      font-weight: 700;
    }

    .section-nav a:hover,
    .section-nav a:focus-visible {
      color: var(--text);
      border-color: var(--accent);
      outline: none;
    }

    .insight-panel {
      margin-bottom: 16px;
    }

    .insight-list {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
    }

    .insight-card {
      border-left: 3px solid var(--accent);
      background: rgba(255, 255, 255, 0.02);
      padding: 12px 12px 12px 14px;
    }

    .insight-card h3 {
      margin-bottom: 6px;
      font-size: 0.92rem;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(6, minmax(0, 1fr));
      gap: 12px;
      margin-bottom: 16px;
    }

    .stat-value {
      font-size: 1.8rem;
      line-height: 1;
      font-weight: 800;
      font-family: "Space Grotesk", "IBM Plex Sans", sans-serif;
    }

    .stat-subvalue {
      margin-top: 8px;
      color: var(--muted);
      font-size: 0.88rem;
      line-height: 1.45;
    }

    .section-grid {
      display: grid;
      gap: 16px;
    }

    .section-grid > *,
    .wide-stack,
    .chart-panel {
      min-width: 0;
      max-width: 100%;
    }

    .section-grid > section,
    .section-grid > .wide-stack > article {
      scroll-margin-top: 82px;
    }

    .chart-panel {
      display: grid;
      gap: 14px;
    }

    .tab-strip {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .tab-button {
      border: 1px solid var(--line-strong);
      background: rgba(255, 255, 255, 0.02);
      color: var(--muted);
      border-radius: 6px;
      padding: 8px 12px;
      font: inherit;
      cursor: pointer;
    }

    .tab-button.active {
      color: var(--text);
      background: rgba(117, 199, 255, 0.12);
      border-color: var(--accent);
    }

    .tab-button:focus-visible,
    .ghost-button:focus-visible,
    .author-button:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    .chart-root {
      border: 1px solid var(--line);
      border-radius: 6px;
      padding: 10px;
      background: rgba(255, 255, 255, 0.015);
      aspect-ratio: 16 / 6;
      min-height: 280px;
      max-width: 100%;
      overflow: hidden;
    }

    .chart-root svg {
      display: block;
      width: 100%;
      height: 100%;
      min-height: 280px;
      overflow: visible;
    }

    .chart-axis {
      fill: var(--muted);
      font-size: 11px;
      font-family: "IBM Plex Mono", "SFMono-Regular", monospace;
    }

    .chart-title {
      display: flex;
      justify-content: space-between;
      gap: 16px;
      align-items: center;
      color: var(--muted);
      font-size: 0.88rem;
    }

    .chart-legend {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .chart-readout {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
    }

    .readout-card {
      border: 1px solid var(--line);
      border-radius: 6px;
      padding: 10px 12px;
      background: rgba(255, 255, 255, 0.02);
    }

    .readout-card strong {
      display: block;
      margin-bottom: 6px;
      color: var(--muted);
      font-size: 0.68rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .readout-card span {
      font-weight: 800;
      font-family: "Space Grotesk", "IBM Plex Sans", sans-serif;
    }

    .legend-chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 10px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.02);
      color: var(--muted);
      font-size: 0.8rem;
    }

    .legend-dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
    }

    .section-actions {
      display: flex;
      justify-content: flex-end;
      margin-bottom: 12px;
    }

    .table-wrap {
      width: 100%;
      max-width: 100%;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .two-col {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: 16px;
    }

    .wide-stack {
      display: grid;
      grid-template-columns: 1fr;
      gap: 16px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.92rem;
    }

    th, td {
      padding: 10px 8px;
      border-bottom: 1px solid var(--line);
      text-align: left;
      vertical-align: middle;
    }

    th {
      color: var(--muted);
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-weight: 700;
    }

    td.num {
      text-align: right;
      font-variant-numeric: tabular-nums;
      font-family: "IBM Plex Mono", "SFMono-Regular", monospace;
    }

    .rank {
      color: var(--muted);
      width: 42px;
    }

    .leader {
      min-width: 180px;
    }

    .leader strong {
      display: block;
      font-size: 0.96rem;
      color: var(--text);
    }

    .leader span {
      display: block;
      margin-top: 4px;
      color: var(--muted);
      font-size: 0.82rem;
    }

    .bar-cell {
      min-width: 200px;
    }

    .delta-badge {
      display: inline-flex;
      justify-content: flex-end;
      min-width: 48px;
      padding: 3px 7px;
      border-radius: 999px;
      font-weight: 700;
      font-size: 0.82rem;
    }

    .delta-badge.positive {
      color: var(--positive);
      background: rgba(126, 224, 179, 0.1);
    }

    .delta-badge.negative {
      color: var(--negative);
      background: rgba(255, 139, 139, 0.1);
    }

    .delta-badge.neutral {
      color: var(--muted);
      background: rgba(255, 255, 255, 0.04);
    }

    .bar-track {
      width: 100%;
      height: 8px;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 999px;
      overflow: hidden;
      margin-bottom: 6px;
    }

    .bar-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--accent), var(--accent-2));
      border-radius: 999px;
    }

    .bar-meta {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      color: var(--muted);
      font-size: 0.8rem;
    }

    .tag-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 12px;
    }

    .tag {
      padding: 7px 10px;
      border: 1px solid var(--line);
      border-radius: 999px;
      color: var(--muted);
      font-size: 0.82rem;
      background: rgba(255, 255, 255, 0.02);
    }

    .ghost-button,
    .author-button {
      border: 1px solid var(--line-strong);
      background: rgba(255, 255, 255, 0.02);
      color: var(--text);
      border-radius: 6px;
      padding: 8px 12px;
      font: inherit;
      cursor: pointer;
    }

    .ghost-button:hover,
    .author-button:hover,
    .author-button.active {
      background: rgba(117, 199, 255, 0.12);
      border-color: var(--accent);
    }

    .hidden {
      display: none;
    }

    .detail-shell {
      display: grid;
      gap: 14px;
    }

    .people-grid {
      display: grid;
      grid-template-columns: minmax(280px, 0.36fr) minmax(0, 0.64fr);
      gap: 16px;
      align-items: start;
    }

    .people-grid > * {
      min-width: 0;
    }

    .person-list {
      display: grid;
      gap: 10px;
    }

    .person-card {
      width: 100%;
      min-width: 0;
      display: grid;
      gap: 8px;
      border: 1px solid var(--line);
      border-left: 3px solid transparent;
      border-radius: 6px;
      padding: 12px;
      background: rgba(255, 255, 255, 0.02);
      color: var(--text);
      font: inherit;
      text-align: left;
      cursor: pointer;
    }

    .person-card:hover,
    .person-card.active {
      border-color: var(--line-strong);
      border-left-color: var(--accent);
      background: rgba(117, 199, 255, 0.08);
    }

    .person-card-header,
    .person-card-metrics,
    .profile-summary {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: baseline;
      min-width: 0;
    }

    .person-card-metrics,
    .profile-summary {
      flex-wrap: wrap;
    }

    .person-card strong {
      font-size: 1rem;
    }

    .person-card small,
    .profile-summary span {
      color: var(--muted);
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .person-card-metrics span {
      color: var(--muted);
      font-size: 0.82rem;
    }

    .person-profile {
      display: grid;
      gap: 14px;
      min-width: 0;
    }

    .person-profile > *,
    .detail-shell,
    .detail-grid,
    .profile-subgrid {
      min-width: 0;
      max-width: 100%;
    }

    .person-profile .detail-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .person-profile .chart-root {
      aspect-ratio: 16 / 5;
      min-height: 220px;
    }

    .person-profile .chart-root svg {
      min-height: 220px;
    }

    .profile-subgrid {
      display: grid;
      grid-template-columns: minmax(0, 1.35fr) minmax(0, 0.9fr) minmax(0, 0.75fr);
      gap: 14px;
    }

    .detail-tabs {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .detail-grid {
      display: grid;
      grid-template-columns: repeat(6, minmax(0, 1fr));
      gap: 10px;
    }

    .detail-card {
      border: 1px solid var(--line);
      border-radius: 6px;
      padding: 12px;
      background: rgba(255, 255, 255, 0.02);
    }

    .detail-card strong {
      display: block;
      margin-bottom: 6px;
      color: var(--muted);
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .detail-card span {
      font-size: 1.1rem;
      font-weight: 700;
    }

    .state-list {
      display: grid;
      gap: 10px;
    }

    .state-row {
      display: grid;
      grid-template-columns: 160px minmax(0, 1fr) 70px;
      gap: 12px;
      align-items: center;
    }

    .state-track {
      height: 10px;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 999px;
      overflow: hidden;
    }

    .state-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--accent-3), var(--accent));
    }

    .small-note {
      color: var(--muted);
      font-size: 0.82rem;
    }

    @media (max-width: 1320px) {
      .stats-grid,
      .detail-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }

    @media (max-width: 1180px) {
      .hero {
        grid-template-columns: 1fr;
      }

      .two-col,
      .insight-list,
      .chart-readout,
      .profile-subgrid {
        grid-template-columns: 1fr;
      }

      .hero-meta {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 860px) {
      .people-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 720px) {
      body { padding: 14px 12px 24px; }

       .hero-panel,
       .insight-panel,
       .section-panel {
        padding: 14px;
      }

      .hero-meta {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .stats-grid,
      .detail-grid,
      .person-profile .detail-grid {
        grid-template-columns: 1fr;
      }

      .table-wrap {
        overflow-x: visible;
      }

      table,
      tbody,
      tr,
      td {
        display: block;
        width: 100%;
      }

      thead {
        display: none;
      }

      tr {
        margin-bottom: 12px;
        padding: 12px;
        border: 1px solid var(--line);
        border-radius: 6px;
        background: rgba(255, 255, 255, 0.02);
      }

      td {
        padding: 7px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
      }

      td:last-child {
        border-bottom: 0;
      }

      td::before {
        content: attr(data-label);
        display: block;
        margin-bottom: 4px;
        color: var(--muted);
        font-size: 0.7rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        font-weight: 700;
      }

      td.rank::before {
        content: "Rank";
      }

      .leader,
      .bar-cell,
      td.num {
        min-width: 0;
        text-align: left;
      }

      .bar-track {
        margin-top: 6px;
      }

      .state-row {
        grid-template-columns: 1fr;
      }

      .bar-cell {
        min-width: 0;
      }

      .section-nav {
        position: static;
      }

      .chart-root {
        aspect-ratio: 4 / 3;
        min-height: 240px;
        max-width: 100%;
        overflow: hidden;
      }

      .chart-root svg {
        min-height: 240px;
      }
    }

    @media (max-width: 360px) {
      .hero-meta {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <div class="shell">
    <section class="hero">
      <div class="panel hero-panel">
        <p class="eyebrow">Engineering Productivity Leaderboard</p>
        <h1>{{ overview.org }} review and throughput board</h1>
        <p class="subtitle">
          Leaderboard view for the selected window. The page focuses on who shipped,
          who reviewed, where flow concentrated, and how review latency moved with PR
          size, with chart tabs for period and person-level inspection.
        </p>
        <div class="hero-meta">
          <div class="meta-box">
            <span class="meta-label">Window</span>
            <span class="meta-value">{{ overview.since }} to {{ overview.until }}</span>
          </div>
          <div class="meta-box">
            <span class="meta-label">Anchor</span>
            <span class="meta-value">{{ overview.time_anchor }}</span>
          </div>
          <div class="meta-box">
            <span class="meta-label">Top repository</span>
            <span class="meta-value">{{ overview.top_repository }}</span>
          </div>
          <div class="meta-box">
            <span class="meta-label">Top author</span>
            <span class="meta-value">{{ overview.top_author }}</span>
          </div>
          {% if overview.distribution_percentile is defined %}
          <div class="meta-box">
            <span class="meta-label">Distribution cutoff</span>
            <span class="meta-value">{{ overview.distribution_percentile }}th percentile</span>
          </div>
          {% endif %}
        </div>
        {% if insights %}
        <div class="primary-readout">
          <p class="section-kicker">Primary readout</p>
          <h2>{{ insights[0].title }}</h2>
          <p class="subtitle">{{ insights[0].body }}</p>
        </div>
        {% endif %}
      </div>
    </section>

    <section class="stats-grid">
      <article class="stat-card">
        <span class="stat-label">PR throughput</span>
        <div class="stat-value">{{ overview.pull_requests | intfmt }}</div>
        <div class="stat-subvalue">{{ overview.merged_pull_requests | intfmt }} merged / {{ overview.open_pull_requests | intfmt }} open</div>
      </article>
      <article class="stat-card">
        <span class="stat-label">Review coverage</span>
        <div class="stat-value">{{ overview.review_coverage_pct }}%</div>
        <div class="stat-subvalue">{{ overview.review_submissions | intfmt }} total review submissions</div>
      </article>
      <article class="stat-card">
        <span class="stat-label">Median first review</span>
        <div class="stat-value">{{ overview.median_first_review_hours | duration }}</div>
        <div class="stat-subvalue">from ready/request to first review</div>
      </article>
      <article class="stat-card">
        <span class="stat-label">Median merge time</span>
        <div class="stat-value">{{ overview.median_merge_hours | duration }}</div>
        <div class="stat-subvalue">from PR creation to merge</div>
      </article>
      <article class="stat-card">
        <span class="stat-label">Changed lines</span>
        <div class="stat-value">{{ overview.total_changed_lines | intfmt }}</div>
        <div class="stat-subvalue">{{ overview.average_changed_lines_per_pr | numfmt }} lines per PR on average</div>
      </article>
      <article class="stat-card">
        <span class="stat-label">Reviewers</span>
        <div class="stat-value">{{ overview.unique_reviewers | intfmt }}</div>
        <div class="stat-subvalue">{{ overview.average_reviews_per_pr | numfmt }} reviews per PR on average</div>
      </article>
    </section>

    <nav class="section-nav" aria-label="Report sections">
      <a href="#trends">Trends</a>
      <a href="#people">People</a>
      <a href="#reviewers">Reviewers</a>
      <a href="#repositories">Repositories</a>
      <a href="#size-review">PR Size</a>
    </nav>

    <div class="section-grid">
      <section id="trends" class="panel section-panel chart-panel">
        <p class="section-kicker">Trend charts</p>
        <h2>Weekly and monthly movement, graphed</h2>
        <p class="section-copy">Switch the metric and time grain to compare throughput, code volume, and review speed without leaving the page.</p>
        <div class="two-col">
          <div class="tab-strip" id="trend-metric-tabs">
            <button type="button" class="tab-button active" data-metric="pull_requests" aria-selected="true">PR throughput</button>
            <button type="button" class="tab-button" data-metric="changed_lines" aria-selected="false">Changed lines</button>
            <button type="button" class="tab-button" data-metric="median_first_review_hours" aria-selected="false">First review</button>
            <button type="button" class="tab-button" data-metric="median_merge_hours" aria-selected="false">Merge time</button>
          </div>
          <div class="tab-strip" id="trend-grain-tabs">
            <button type="button" class="tab-button active" data-grain="weekly" aria-selected="true">Weekly</button>
            <button type="button" class="tab-button" data-grain="monthly" aria-selected="false">Monthly</button>
          </div>
        </div>
        <div class="chart-title">
          <span id="trend-chart-title">PR throughput by week</span>
          <div class="chart-legend">
            <span class="legend-chip"><span class="legend-dot" style="background: var(--accent)"></span>Selected metric</span>
          </div>
        </div>
        <div id="trend-chart-readout" class="chart-readout"></div>
        <div id="trend-chart-root" class="chart-root"></div>
      </section>

      <section class="wide-stack">
        <article class="panel section-panel">
          <p class="section-kicker">Weekly trend</p>
          <h2>Created-time weekly movement</h2>
          <p class="section-copy">Week-over-week flow by PR creation period. Use the deltas to see acceleration and slowdown.</p>
          <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Week</th>
                <th class="num">PRs</th>
                <th class="num">Delta</th>
                <th class="num">Merged</th>
                <th class="num">Open</th>
                <th class="num">Changed lines</th>
                <th class="num">Line delta</th>
                <th class="num">Reviews / PR</th>
                <th class="num">Median first review</th>
              </tr>
            </thead>
            <tbody>
              {% for row in weekly_trends %}
              <tr>
                <td class="leader" data-label="Week">
                  <strong>{{ row.period_key }}</strong>
                  <span>created_at basis</span>
                </td>
                <td class="num" data-label="PRs">{{ row.pull_requests | intfmt }}</td>
