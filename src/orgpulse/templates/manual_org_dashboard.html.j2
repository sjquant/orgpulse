  </div>
  <script id="author-details-data" type="application/json">{{ author_details_json | safe }}</script>
  <script>
    const authorDetails = JSON.parse(document.getElementById("author-details-data").textContent);
    const authorButtons = Array.from(document.querySelectorAll(".author-button"));
    const authorDetailRoot = document.getElementById("author-detail-root");
    const authorDetailPanel = document.getElementById("author-detail");
    const authorDetailTitle = document.getElementById("author-detail-title");
    const authorChartRoot = document.getElementById("author-chart-root");
    const authorChartReadout = document.getElementById("author-chart-readout");
    const authorChartTitle = document.getElementById("author-chart-title");
    const repositoryToggle = document.getElementById("repository-toggle");
    const repositoryExtra = document.getElementById("repository-extra");
    const trendChartRoot = document.getElementById("trend-chart-root");
    const trendChartReadout = document.getElementById("trend-chart-readout");
    const trendChartTitle = document.getElementById("trend-chart-title");
    const trendMetricTabs = Array.from(document.querySelectorAll("#trend-metric-tabs .tab-button"));
    const trendGrainTabs = Array.from(document.querySelectorAll("#trend-grain-tabs .tab-button"));
    const authorMetricTabs = Array.from(document.querySelectorAll("#author-detail-metric-tabs .tab-button"));
    const authorGrainTabs = Array.from(document.querySelectorAll("#author-detail-grain-tabs .tab-button"));
    const trendSeries = {
      weekly: {{ weekly_trends | tojson }},
      monthly: {{ monthly_trends | tojson }},
    };
    let activeTrendMetric = "pull_requests";
    let activeTrendGrain = trendSeries.weekly.length > 12 ? "monthly" : "weekly";
    let activeAuthorMetric = "pull_requests";
    let activeAuthorGrain = "weekly";
    let activeAuthor = "{{ default_author }}";
    if (authorDetails[activeAuthor]?.weekly_trends?.length > 12) {
      activeAuthorGrain = "monthly";
    }

    syncTabs(
      trendGrainTabs,
      trendGrainTabs.find((button) => button.dataset.grain === activeTrendGrain),
    );
    syncTabs(
      authorGrainTabs,
      authorGrainTabs.find((button) => button.dataset.authorGrain === activeAuthorGrain),
    );

    if (repositoryToggle && repositoryExtra) {
      repositoryToggle.addEventListener("click", () => {
        const isHidden = repositoryExtra.classList.contains("hidden");
        repositoryExtra.classList.toggle("hidden", !isHidden);
        repositoryToggle.setAttribute("aria-expanded", String(isHidden));
        repositoryToggle.textContent = isHidden
          ? "Collapse repository list"
          : `Show ${repositoryExtra.querySelectorAll("tr").length} more repositories`;
      });
    }

    for (const button of authorButtons) {
      button.addEventListener("click", () => {
        for (const other of authorButtons) {
          other.classList.toggle("active", other === button);
          other.setAttribute("aria-pressed", String(other === button));
        }
        activeAuthor = button.dataset.author;
        renderAuthorDetail(activeAuthor, { focus: true });
      });
    }

    for (const button of trendMetricTabs) {
      button.addEventListener("click", () => {
        activeTrendMetric = button.dataset.metric;
        syncTabs(trendMetricTabs, button);
        renderTrendChart();
      });
    }

    for (const button of trendGrainTabs) {
      button.addEventListener("click", () => {
        activeTrendGrain = button.dataset.grain;
        syncTabs(trendGrainTabs, button);
        renderTrendChart();
      });
    }

    for (const button of authorMetricTabs) {
      button.addEventListener("click", () => {
        activeAuthorMetric = button.dataset.authorMetric;
        syncTabs(authorMetricTabs, button);
        renderAuthorDetail(activeAuthor);
      });
    }

    for (const button of authorGrainTabs) {
      button.addEventListener("click", () => {
        activeAuthorGrain = button.dataset.authorGrain;
        syncTabs(authorGrainTabs, button);
        renderAuthorDetail(activeAuthor);
      });
    }

    window.addEventListener("resize", () => {
      renderTrendChart();
      renderAuthorDetail(activeAuthor);
    });

    renderTrendChart();
    renderAuthorDetail(activeAuthor);

    function renderAuthorDetail(authorLogin, options = {}) {
      const detail = authorDetails[authorLogin];
      if (!detail) {
        authorDetailRoot.innerHTML = "";
        authorDetailTitle.textContent = "Person detail";
        return;
      }
      const summary = detail.summary;
      authorDetailTitle.textContent = `${authorLogin} profile`;
      renderAuthorChart(detail, authorLogin);
      authorDetailRoot.innerHTML = `
        <div class="detail-grid">
          ${detailCard("Authored PRs", summary.pull_requests)}
          ${detailCard("Reviewed PRs", summary.pull_requests_reviewed)}
          ${detailCard("Reviews given", summary.review_submissions_given)}
          ${detailCard("Merge rate", formatMetric(summary.merge_rate_pct, "%"))}
          ${detailCard("Avg lines / PR", formatMetric(summary.average_changed_lines_per_pr))}
          ${detailCard("First review", formatDuration(summary.median_first_review_hours))}
        </div>
        <div class="profile-subgrid">
          <div>
            <p class="section-kicker">Delivery footprint</p>
            ${renderMiniTable(
              [
                ["Repository", "repository_full_name"],
                ["PRs", "pull_requests"],
                ["Changed lines", "changed_lines"],
              ],
              detail.top_repositories,
            )}
          </div>
          <div>
            <p class="section-kicker">Review footprint</p>
            ${renderMiniTable(
              [
                ["Signal", "label"],
                ["Count", "value"],
              ],
              [
                { label: "Approvals", value: summary.approvals_given },
                { label: "Changes requested", value: summary.changes_requested_given },
                { label: "Comments", value: summary.review_comments_given },
                { label: "Authors supported", value: summary.authors_supported },
              ],
            )}
          </div>
          <div>
            <p class="section-kicker">Size mix</p>
            ${renderMiniTable(
              [
                ["Size", "bucket"],
                ["PRs", "pull_requests"],
              ],
              detail.size_mix,
            )}
          </div>
        </div>
      `;
      if (options.focus) {
        authorDetailPanel.scrollIntoView({ block: "start" });
        authorDetailPanel.focus({ preventScroll: true });
      }
    }

    function renderTrendChart() {
      const rows = trendSeries[activeTrendGrain];
      const label = activeTrendGrain === "weekly" ? "week" : "month";
      trendChartTitle.textContent = `${metricLabel(activeTrendMetric)} by ${label}`;
      trendChartReadout.innerHTML = renderSeriesReadout({
        rows,
        metric: activeTrendMetric,
        labelKey: "period_key",
      });
      renderSeriesChart({
        element: trendChartRoot,
        rows,
        metric: activeTrendMetric,
        labelKey: "period_key",
      });
    }

    function renderAuthorChart(detail, authorLogin) {
      if (activeAuthorGrain === "mix") {
        authorChartTitle.textContent = `${authorLogin} ${metricLabel(activeAuthorMetric)} by PR size`;
        authorChartReadout.innerHTML = renderBarReadout({
          rows: detail.size_mix,
          metric: activeAuthorMetric,
          labelKey: "bucket",
          valueKey: mixMetricKey(activeAuthorMetric),
        });
        renderBarChart({
          element: authorChartRoot,
          rows: detail.size_mix,
          labelKey: "bucket",
          valueKey: mixMetricKey(activeAuthorMetric),
          metric: activeAuthorMetric,
        });
        return;
      }
      const rows = detail[`${activeAuthorGrain}_trends`];
      const label = activeAuthorGrain === "weekly" ? "week" : "month";
      authorChartTitle.textContent = `${authorLogin} ${metricLabel(activeAuthorMetric)} by ${label}`;
      authorChartReadout.innerHTML = renderSeriesReadout({
        rows,
        metric: activeAuthorMetric,
        labelKey: "period_key",
      });
      renderSeriesChart({
        element: authorChartRoot,
        rows,
        metric: activeAuthorMetric,
        labelKey: "period_key",
      });
    }

    function renderSeriesChart({ element, rows, metric, labelKey, secondaryMetric = null }) {
      if (!rows || rows.length === 0) {
        element.innerHTML = `<div class="small-note">No data for this view.</div>`;
        return;
      }
      const width = 920;
      const height = 320;
      const padding = { top: 20, right: 18, bottom: 42, left: 56 };
      const plotWidth = width - padding.left - padding.right;
      const plotHeight = height - padding.top - padding.bottom;
      const metricValues = rows.map((row) => toNumeric(row[metric]));
      const primaryValues = metricValues.filter((value) => value !== null);
      if (primaryValues.length === 0) {
        element.innerHTML = `<div class="small-note">No data for this metric in the selected window.</div>`;
        return;
      }
      const secondaryValues = secondaryMetric
        ? rows
            .map((row) => toNumeric(row[secondaryMetric]))
            .filter((value) => value !== null)
        : [];
      const maxValue = Math.max(1, ...primaryValues, ...secondaryValues);
      const stepX = rows.length > 1 ? plotWidth / (rows.length - 1) : plotWidth / 2;
      const yFor = (value) => padding.top + plotHeight - (value / maxValue) * plotHeight;
      const xFor = (index) => padding.left + index * stepX;
      const linePoints = rows
        .map((row, index) => ({ index, value: toNumeric(row[metric]) }))
        .filter((point) => point.value !== null);
      const linePath = linePoints
        .map((point, pathIndex) => `${pathIndex === 0 ? "M" : "L"} ${xFor(point.index)} ${yFor(point.value)}`)
        .join(" ");
      const areaPath = linePoints.length
        ? `${linePath} L ${xFor(linePoints.at(-1).index)} ${padding.top + plotHeight} L ${xFor(linePoints[0].index)} ${padding.top + plotHeight} Z`
        : "";
      let secondaryPath = "";
      if (secondaryMetric) {
        const secondaryPoints = rows
          .map((row, index) => ({ index, value: toNumeric(row[secondaryMetric]) }))
          .filter((point) => point.value !== null);
        secondaryPath = secondaryPoints
          .map((point, pathIndex) => `${pathIndex === 0 ? "M" : "L"} ${xFor(point.index)} ${yFor(point.value)}`)
          .join(" ");
      }
      const averageValue = primaryValues.reduce((sum, value) => sum + value, 0) / primaryValues.length;
      const averageLineY = yFor(averageValue);
      const labelInterval = chartLabelInterval(rows.length);
      const points = rows.map((row, index) => {
        const value = toNumeric(row[metric]);
        if (value === null) {
          return "";
        }
        const showLabel = index === 0 || index === rows.length - 1 || index % labelInterval === 0;
        return `
          <circle cx="${xFor(index)}" cy="${yFor(value)}" r="4" fill="${getCss("--accent")}">
            <title>${formatCell(row[labelKey])}: ${formatChartValue(value, metric)}</title>
          </circle>
          ${showLabel ? `<text x="${xFor(index)}" y="${height - 12}" text-anchor="middle" class="chart-axis">${shortLabel(row[labelKey])}</text>` : ""}
        `;
      }).join("");
      const ticks = [0, 0.25, 0.5, 0.75, 1].map((ratio) => {
        const value = maxValue * ratio;
        const y = padding.top + plotHeight - plotHeight * ratio;
        return `
          <line x1="${padding.left}" x2="${width - padding.right}" y1="${y}" y2="${y}" stroke="rgba(255,255,255,0.06)"></line>
          <text x="${padding.left - 10}" y="${y + 4}" text-anchor="end" class="chart-axis">${formatChartValue(value, metric)}</text>
        `;
      }).join("");
      element.innerHTML = `
        <svg viewBox="0 0 ${width} ${height}" preserveAspectRatio="xMidYMid meet" role="img" aria-label="${metricLabel(metric)} chart">
          <defs>
            <linearGradient id="series-fill-${metric}" x1="0" x2="0" y1="0" y2="1">
              <stop offset="0%" stop-color="${getCss("--accent")}" stop-opacity="0.22"></stop>
              <stop offset="100%" stop-color="${getCss("--accent")}" stop-opacity="0"></stop>
            </linearGradient>
          </defs>
          ${ticks}
          <line x1="${padding.left}" x2="${width - padding.right}" y1="${averageLineY}" y2="${averageLineY}" stroke="rgba(126,224,179,0.4)" stroke-dasharray="5 5"></line>
          ${areaPath ? `<path d="${areaPath}" fill="url(#series-fill-${metric})"></path>` : ""}
          <path d="${linePath}" fill="none" stroke="${getCss("--accent")}" stroke-width="3" stroke-linecap="round"></path>
          ${secondaryPath ? `<path d="${secondaryPath}" fill="none" stroke="${getCss("--accent-3")}" stroke-width="2" stroke-dasharray="6 6"></path>` : ""}
          ${points}
        </svg>
      `;
    }

    function renderBarChart({ element, rows, labelKey, valueKey, metric }) {
      if (!rows || rows.length === 0) {
        element.innerHTML = `<div class="small-note">No data for this view.</div>`;
        return;
      }
      const width = 920;
      const height = 320;
      const padding = { top: 20, right: 18, bottom: 42, left: 56 };
      const plotWidth = width - padding.left - padding.right;
      const plotHeight = height - padding.top - padding.bottom;
      const barValues = rows
        .map((row) => toNumeric(row[valueKey]))
        .filter((value) => value !== null);
      if (barValues.length === 0) {
        element.innerHTML = `<div class="small-note">No data for this metric in the selected window.</div>`;
        return;
      }
      const maxValue = Math.max(1, ...barValues);
      const groupWidth = plotWidth / rows.length;
      const barWidth = Math.min(56, groupWidth * 0.58);
      const labelInterval = chartLabelInterval(rows.length);
      const bars = rows.map((row, index) => {
        const value = toNumeric(row[valueKey]);
        const barHeight = value === null ? 0 : (value / maxValue) * plotHeight;
        const x = padding.left + index * groupWidth + (groupWidth - barWidth) / 2;
        const y = padding.top + plotHeight - barHeight;
        const labelX = padding.left + index * groupWidth + groupWidth / 2;
        const showLabel = index === 0 || index === rows.length - 1 || index % labelInterval === 0;
        return `
          <rect x="${x}" y="${y}" width="${barWidth}" height="${barHeight}" rx="5" fill="${getCss("--accent-2")}" fill-opacity="${value === null ? "0.16" : "1"}">
            <title>${formatCell(row[labelKey])}: ${formatChartValue(value, metric)}</title>
          </rect>
          ${value === null ? "" : `<text x="${labelX}" y="${Math.max(y - 8, padding.top + 10)}" text-anchor="middle" class="chart-axis">${formatChartValue(value, metric)}</text>`}
          ${showLabel ? `<text x="${labelX}" y="${height - 12}" text-anchor="middle" class="chart-axis">${shortLabel(row[labelKey])}</text>` : ""}
        `;
      }).join("");
      const ticks = [0, 0.25, 0.5, 0.75, 1].map((ratio) => {
        const value = maxValue * ratio;
        const y = padding.top + plotHeight - plotHeight * ratio;
        return `
          <line x1="${padding.left}" x2="${width - padding.right}" y1="${y}" y2="${y}" stroke="rgba(255,255,255,0.06)"></line>
          <text x="${padding.left - 10}" y="${y + 4}" text-anchor="end" class="chart-axis">${formatChartValue(value, metric)}</text>
        `;
      }).join("");
      element.innerHTML = `
        <svg viewBox="0 0 ${width} ${height}" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Bar chart">
          ${ticks}
          ${bars}
        </svg>
      `;
    }

    function renderMiniTable(columns, rows) {
      const head = columns.map(([label]) => `<th>${label}</th>`).join("");
      const body = rows.map((row) => `
        <tr>
          ${columns.map(([label, key]) => {
            const value = row[key];
            const numericClass = typeof value === "number" ? ` class="num"` : "";
            return `<td${numericClass} data-label="${formatCell(label)}">${formatCell(value)}</td>`;
          }).join("")}
        </tr>
      `).join("");
      return `<div class="table-wrap"><table><thead><tr>${head}</tr></thead><tbody>${body}</tbody></table></div>`;
    }

    function detailCard(label, value) {
      return `<div class="detail-card"><strong>${label}</strong><span>${formatCell(value)}</span></div>`;
    }

    function renderSeriesReadout({ rows, metric, labelKey }) {
      if (!rows || rows.length === 0) {
        return "";
      }
      const rowsWithValues = rows.filter((row) => toNumeric(row[metric]) !== null);
      if (rowsWithValues.length === 0) {
        return [
          ["Latest period", "-"],
          ["Latest value", "-"],
          ["Period delta", "-"],
          ["Window average", "-"],
        ].map(([label, value]) => `<div class="readout-card"><strong>${label}</strong><span>${value}</span></div>`).join("");
      }
      const latest = rowsWithValues.at(-1);
      const previous = rowsWithValues.length > 1 ? rowsWithValues.at(-2) : null;
      const latestValue = toNumeric(latest[metric]);
      const previousValue = previous ? toNumeric(previous[metric]) : null;
      const delta = previousValue === null ? null : latestValue - previousValue;
      const average = rowsWithValues.reduce((sum, row) => sum + toNumeric(row[metric]), 0) / rowsWithValues.length;
      return [
        ["Latest period", latest[labelKey]],
        ["Latest value", formatChartValue(latestValue, metric)],
        ["Period delta", formatDelta(delta)],
        ["Window average", formatChartValue(average, metric)],
      ].map(([label, value]) => `<div class="readout-card"><strong>${label}</strong><span>${value}</span></div>`).join("");
    }

    function renderBarReadout({ rows, metric, labelKey, valueKey }) {
      if (!rows || rows.length === 0) {
        return "";
      }
      const ranked = [...rows]
        .filter((row) => toNumeric(row[valueKey]) !== null)
        .sort((left, right) => toNumeric(right[valueKey]) - toNumeric(left[valueKey]));
      if (ranked.length === 0) {
        return [
          ["Leading bucket", "-"],
          ["Leading value", "-"],
          ["Bucket average", "-"],
          ["Metric", metricLabel(metric)],
        ].map(([label, value]) => `<div class="readout-card"><strong>${label}</strong><span>${value}</span></div>`).join("");
      }
      const top = ranked[0];
      const total = ranked.reduce((sum, row) => sum + toNumeric(row[valueKey]), 0);
      const average = ranked.length ? total / ranked.length : 0;
      return [
        ["Leading bucket", formatCell(top[labelKey])],
        ["Leading value", formatChartValue(Number(top[valueKey] ?? 0), metric)],
        ["Bucket average", formatChartValue(average, metric)],
        ["Metric", metricLabel(metric)],
      ].map(([label, value]) => `<div class="readout-card"><strong>${label}</strong><span>${value}</span></div>`).join("");
    }

    function formatMetric(value, suffix = "") {
      if (value === null || value === undefined || value === "") {
        return "-";
      }
      return `${formatCell(value)}${suffix}`;
    }

    function metricLabel(metric) {
      const labels = {
        pull_requests: "PR throughput",
        changed_lines: "Changed lines",
        median_first_review_hours: "Median first review",
        median_merge_hours: "Median merge",
      };
      return labels[metric] || metric;
    }

    function mixMetricKey(metric) {
      const keys = {
        pull_requests: "pull_requests",
        changed_lines: "changed_lines",
        median_first_review_hours: "median_first_review_hours",
        median_merge_hours: "median_merge_hours",
      };
      return keys[metric] || "pull_requests";
    }

    function syncTabs(buttons, activeButton) {
      for (const button of buttons) {
        button.classList.toggle("active", button === activeButton);
        button.setAttribute("aria-selected", String(button === activeButton));
      }
    }

    function chartLabelInterval(rowCount) {
      const width = window.innerWidth || 1200;
      if (width < 520) {
        return Math.max(1, Math.ceil(rowCount / 4));
      }
      if (width < 900) {
        return Math.max(1, Math.ceil(rowCount / 6));
      }
      return Math.max(1, Math.ceil(rowCount / 10));
    }

    function shortLabel(value) {
      const text = String(value);
      return text.includes("-W") ? text.replace(/^20/, "") : text;
    }

    function formatChartValue(value, metric) {
      if (value === null || value === undefined || Number.isNaN(Number(value))) {
        return "-";
      }
      if (metric.includes("_hours")) {
        return formatDuration(value);
      }
      return formatCell(value);
    }

    function formatDelta(value) {
      if (value === null || value === undefined || Number.isNaN(Number(value))) {
        return "-";
      }
      const numericValue = Number(value);
      const sign = numericValue > 0 ? "+" : "";
      return `${sign}${formatCell(numericValue)}`;
    }

    function toNumeric(value) {
      if (value === null || value === undefined || value === "") {
        return null;
      }
      const numericValue = Number(value);
      return Number.isNaN(numericValue) ? null : numericValue;
    }

    function formatDuration(hours) {
      if (hours === null || hours === undefined || Number.isNaN(Number(hours))) {
        return "-";
      }
      const numericHours = Number(hours);
      if (numericHours < 1) {
        return `${Math.round(numericHours * 60)} min`;
      }
      if (numericHours >= 24) {
        return `${(numericHours / 24).toLocaleString(undefined, { maximumFractionDigits: 1 })} d`;
      }
      return `${numericHours.toLocaleString(undefined, { maximumFractionDigits: 1 })} h`;
    }

    function getCss(variableName) {
      return getComputedStyle(document.documentElement).getPropertyValue(variableName).trim();
    }

    function formatCell(value) {
      if (value === null || value === undefined || value === "") {
        return "-";
      }
      if (typeof value === "number") {
        return value.toLocaleString(undefined, { maximumFractionDigits: 2 });
      }
      return String(value)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;");
    }
  </script>
</body>
</html>
