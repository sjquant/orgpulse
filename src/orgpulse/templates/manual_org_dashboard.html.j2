                <td class="num" data-label="Reviews / PR">{{ row.average_reviews_per_pr | numfmt }}</td>
                <td class="num" data-label="Median first review">{{ row.median_first_review_hours | duration }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
          </div>
        </article>

        <article class="panel section-panel">
          <p class="section-kicker">Monthly trend</p>
          <h2>Created-time monthly movement</h2>
          <p class="section-copy">Month-level summary for throughput, code volume, and review responsiveness.</p>
          <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Month</th>
                <th class="num">PRs</th>
                <th class="num">Merged</th>
                <th class="num">Open</th>
                <th class="num">Changed lines</th>
                <th class="num">Reviews / PR</th>
                <th class="num">Median first review</th>
                <th class="num">Median merge</th>
