<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ overview.org }} productivity leaderboard</title>
  <script>
    (function () {
      const storageKey = "orgpulse-manual-dashboard-theme";
      const preferredTheme = window.matchMedia("(prefers-color-scheme: dark)").matches
        ? "dark"
        : "light";
      try {
        const storedTheme = window.localStorage.getItem(storageKey);
        document.documentElement.dataset.theme = storedTheme || preferredTheme;
      } catch (_error) {
        document.documentElement.dataset.theme = preferredTheme;
      }
    }());
  </script>
  <style>
    :root {
      color-scheme: dark;
      --font-sans: "IBM Plex Sans", "Helvetica Neue", sans-serif;
      --font-display: "Space Grotesk", "IBM Plex Sans", sans-serif;
      --font-mono: "IBM Plex Mono", "SFMono-Regular", monospace;
      --radius-panel: 8px;
      --radius-control: 6px;
      --radius-pill: 999px;
      --bg-canvas: #070b12;
      --bg-canvas-top: #060910;
      --bg-glow: rgba(117, 199, 255, 0.05);
      --bg-section-nav: rgba(7, 11, 18, 0.9);
      --panel-raised: linear-gradient(180deg, rgba(16, 24, 39, 0.96), rgba(10, 16, 28, 0.98));
      --panel-subtle: rgba(255, 255, 255, 0.02);
      --panel-muted: rgba(255, 255, 255, 0.015);
      --line: #1d2738;
      --line-strong: #2b3952;
      --line-soft: rgba(255, 255, 255, 0.06);
      --line-faint: rgba(255, 255, 255, 0.04);
      --text: #e8edf7;
      --muted: #8ea0bf;
      --accent: #75c7ff;
      --accent-2: #7ee0b3;
      --accent-3: #f0b35f;
      --danger: #ff8b8b;
      --positive: #7ee0b3;
      --negative: #ff8b8b;
      --track: rgba(255, 255, 255, 0.05);
      --active-fill: rgba(117, 199, 255, 0.12);
      --readout-fill: rgba(117, 199, 255, 0.06);
      --readout-border: rgba(117, 199, 255, 0.28);
      --grid-stroke: rgba(255, 255, 255, 0.06);
      --avg-stroke: rgba(126, 224, 179, 0.4);
      --theme-toggle-bg: rgba(255, 255, 255, 0.02);
      --theme-toggle-active: rgba(117, 199, 255, 0.16);
      --theme-toggle-hover: rgba(117, 199, 255, 0.08);
      --theme-toggle-indicator-shadow: 0 8px 18px rgba(4, 10, 18, 0.22);
      --shadow: 0 10px 30px rgba(0, 0, 0, 0.28);
    }

    :root[data-theme="light"] {
      color-scheme: light;
      --bg-canvas: #eef3fb;
      --bg-canvas-top: #f8fbff;
      --bg-glow: rgba(38, 100, 174, 0.08);
      --bg-section-nav: rgba(248, 251, 255, 0.92);
      --panel-raised: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(243, 247, 253, 0.98));
      --panel-subtle: rgba(14, 22, 37, 0.03);
      --panel-muted: rgba(14, 22, 37, 0.025);
      --line: #d2deed;
      --line-strong: #b5c7e0;
      --line-soft: rgba(85, 109, 138, 0.14);
      --line-faint: rgba(85, 109, 138, 0.1);
      --text: #0f1b2d;
      --muted: #566d8a;
      --accent: #2567b0;
      --accent-2: #1c8f68;
      --accent-3: #b77417;
      --danger: #c04444;
      --positive: #187e59;
      --negative: #be4848;
      --track: rgba(85, 109, 138, 0.12);
      --active-fill: rgba(37, 103, 176, 0.1);
      --readout-fill: rgba(37, 103, 176, 0.07);
      --readout-border: rgba(37, 103, 176, 0.2);
      --grid-stroke: rgba(85, 109, 138, 0.15);
      --avg-stroke: rgba(28, 143, 104, 0.35);
      --theme-toggle-bg: rgba(14, 22, 37, 0.03);
      --theme-toggle-active: rgba(37, 103, 176, 0.12);
      --theme-toggle-hover: rgba(37, 103, 176, 0.08);
      --theme-toggle-indicator-shadow: 0 10px 18px rgba(80, 111, 152, 0.16);
      --shadow: 0 12px 28px rgba(26, 40, 65, 0.1);
    }

    * { box-sizing: border-box; }

    html, body {
      margin: 0;
      min-height: 100%;
      background:
        linear-gradient(180deg, var(--bg-glow), transparent 220px),
        linear-gradient(180deg, var(--bg-canvas-top) 0%, var(--bg-canvas) 100%);
      color: var(--text);
      font-family: var(--font-sans);
    }

    html {
      scroll-behavior: smooth;
    }

    body { padding: 24px 20px 36px; }

    .shell {
      max-width: 1440px;
      margin: 0 auto;
    }

    .hero {
      display: grid;
      gap: 16px;
      align-items: start;
      margin-bottom: 16px;
    }

    .panel {
      background: var(--panel-raised);
      border: 1px solid var(--line);
      border-radius: var(--radius-panel);
      box-shadow: var(--shadow);
      min-width: 0;
    }

    .hero-panel,
    .insight-panel,
    .section-panel {
      padding: 18px 20px;
    }

    .eyebrow,
    .section-kicker {
      margin: 0 0 10px;
      color: var(--accent);
      font-size: 0.72rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      font-weight: 700;
    }

    h1, h2, h3, p { margin-top: 0; }

    h1 {
      margin-bottom: 10px;
      font-size: clamp(2rem, 2.8vw, 3.3rem);
      line-height: 0.98;
      letter-spacing: -0.03em;
      font-family: var(--font-display);
    }

    h2 {
      margin-bottom: 8px;
      font-size: 1.05rem;
      letter-spacing: -0.01em;
    }

    .subtitle,
    .section-copy,
    .insight-card p,
    .table-footnote {
      color: var(--muted);
      line-height: 1.55;
    }

    .hero-meta {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
      margin-top: 16px;
    }

    .hero-head {
      display: flex;
      justify-content: space-between;
      align-items: start;
      gap: 16px;
    }

    .hero-copy {
      min-width: 0;
    }

    .theme-switch {
      position: relative;
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 4px;
      border: 1px solid var(--line);
      border-radius: var(--radius-control);
      background: var(--theme-toggle-bg);
      flex-shrink: 0;
      isolation: isolate;
    }

    .theme-switch-indicator {
      position: absolute;
      top: 4px;
      left: 4px;
      width: 36px;
      height: 36px;
      border-radius: 4px;
      background: var(--theme-toggle-active);
      box-shadow: var(--theme-toggle-indicator-shadow);
      transition:
        transform 180ms cubic-bezier(0.22, 1, 0.36, 1),
        background 160ms ease,
        box-shadow 180ms ease;
      z-index: 0;
      pointer-events: none;
    }

    .theme-switch[data-active-theme="light"] .theme-switch-indicator {
      transform: translateX(40px);
    }

    .theme-switch-button {
      border: 0;
      background: transparent;
      color: var(--muted);
      border-radius: 4px;
      width: 36px;
      height: 36px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      cursor: pointer;
      position: relative;
      z-index: 1;
      transition:
        color 160ms ease,
        transform 180ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .theme-switch-button:hover {
      color: var(--text);
      transform: translateY(-1px);
    }

    .theme-switch-button[aria-pressed="true"] {
      color: var(--text);
    }

    .theme-switch-icon {
      width: 18px;
      height: 18px;
      display: block;
      stroke: currentColor;
      fill: none;
      stroke-width: 1.8;
      stroke-linecap: round;
      stroke-linejoin: round;
      transition:
        transform 220ms cubic-bezier(0.22, 1, 0.36, 1),
        opacity 160ms ease;
    }

    .theme-switch-button[aria-pressed="true"] .theme-switch-icon {
      transform: scale(1.04);
    }

    .theme-switch-button[data-theme-option="light"]:hover .theme-switch-icon,
    .theme-switch-button[data-theme-option="light"][aria-pressed="true"] .theme-switch-icon {
      transform: rotate(12deg) scale(1.04);
    }

    .theme-switch-button[data-theme-option="dark"]:hover .theme-switch-icon,
    .theme-switch-button[data-theme-option="dark"][aria-pressed="true"] .theme-switch-icon {
      transform: rotate(-10deg) scale(1.04);
    }

    .meta-box,
    .stat-card {
      background: var(--panel-subtle);
      border: 1px solid var(--line);
      border-radius: var(--radius-control);
      padding: 12px 14px;
    }

    .meta-label,
    .stat-label {
      display: block;
      margin-bottom: 6px;
      color: var(--muted);
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      font-weight: 700;
    }

    .meta-value {
      font-size: 0.95rem;
      font-weight: 700;
      overflow-wrap: anywhere;
    }

    .section-nav {
      position: sticky;
      top: 0;
      z-index: 5;
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 16px;
      padding: 10px;
      border: 1px solid var(--line);
      border-radius: var(--radius-panel);
      background: var(--bg-section-nav);
      backdrop-filter: blur(14px);
    }

    .section-nav a {
      color: var(--muted);
      text-decoration: none;
      border: 1px solid var(--line);
      border-radius: var(--radius-pill);
      padding: 7px 10px;
      font-size: 0.82rem;
      font-weight: 700;
    }

    .section-nav a[aria-current="true"] {
      color: var(--text);
      border-color: var(--accent);
      background: var(--active-fill);
      box-shadow: inset 0 0 0 1px rgba(117, 199, 255, 0.14);
    }

    .section-nav a:hover,
    .section-nav a:focus-visible {
      color: var(--text);
      border-color: var(--accent);
      outline: none;
    }

    .insight-panel {
      margin-bottom: 16px;
    }

    .insight-list {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
    }

    .insight-card {
      border-left: 3px solid var(--accent);
      background: var(--panel-subtle);
      padding: 12px 12px 12px 14px;
    }

    .insight-card h3 {
      margin-bottom: 6px;
      font-size: 0.92rem;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(6, minmax(0, 1fr));
      gap: 12px;
      margin-bottom: 16px;
    }

    .stat-value {
      font-size: 1.8rem;
      line-height: 1;
      font-weight: 800;
      font-family: var(--font-display);
    }

    .stat-subvalue {
      margin-top: 8px;
      color: var(--muted);
      font-size: 0.88rem;
      line-height: 1.45;
    }

    .section-grid {
      display: grid;
      gap: 16px;
    }

    .section-grid > *,
    .wide-stack,
    .chart-panel {
      min-width: 0;
      max-width: 100%;
    }

    .section-grid > section,
    .section-grid > .wide-stack > article {
      scroll-margin-top: 82px;
    }

    .chart-panel {
      display: grid;
      gap: 14px;
    }

    .tab-strip {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .tab-button {
      border: 1px solid var(--line-strong);
      background: var(--panel-subtle);
      color: var(--muted);
      border-radius: var(--radius-control);
      padding: 8px 12px;
      font: inherit;
      cursor: pointer;
    }

    .tab-button.active {
      color: var(--text);
      background: var(--active-fill);
      border-color: var(--accent);
    }

    .tab-button:focus-visible,
    .theme-switch-button:focus-visible,
    .ghost-button:focus-visible,
    .author-button:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    .chart-root {
      position: relative;
      border: 1px solid var(--line);
      border-radius: var(--radius-control);
      padding: 10px;
      background: var(--panel-muted);
      aspect-ratio: 16 / 6;
      min-height: 280px;
      max-width: 100%;
      overflow: hidden;
    }

    .chart-root svg {
      display: block;
      width: 100%;
      height: 100%;
      min-height: 280px;
      overflow: visible;
    }

    .chart-node {
      cursor: pointer;
    }

    .chart-tooltip {
      position: absolute;
      left: 0;
      top: 0;
      min-width: 148px;
      max-width: min(220px, calc(100% - 20px));
      padding: 9px 10px;
      border: 1px solid var(--line-strong);
      border-radius: var(--radius-control);
      background: color-mix(in srgb, var(--panel-raised) 94%, black 6%);
      box-shadow: 0 16px 28px rgba(0, 0, 0, 0.22);
      pointer-events: none;
      z-index: 2;
    }

    .chart-tooltip strong,
    .chart-tooltip span {
      display: block;
    }

    .chart-tooltip strong {
      margin-bottom: 4px;
      color: var(--text);
      font-size: 0.82rem;
      font-family: var(--font-display);
    }

    .chart-tooltip span {
      color: var(--muted);
      font-size: 0.76rem;
      line-height: 1.45;
    }

    .chart-axis {
      fill: var(--muted);
      font-size: 11px;
      font-family: var(--font-mono);
    }

    .chart-title {
      display: flex;
      justify-content: space-between;
      gap: 16px;
      align-items: center;
      color: var(--muted);
      font-size: 0.88rem;
    }

    .chart-legend {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .chart-readout {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
    }

    .readout-card {
      border: 1px solid var(--line);
      border-radius: var(--radius-control);
      padding: 10px 12px;
      background: var(--panel-subtle);
    }

    .readout-card strong {
      display: block;
      margin-bottom: 6px;
      color: var(--muted);
      font-size: 0.68rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .readout-card span {
      font-weight: 800;
      font-family: var(--font-display);
    }

    .legend-chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 10px;
      border-radius: var(--radius-pill);
      border: 1px solid var(--line);
      background: var(--panel-subtle);
      color: var(--muted);
      font-size: 0.8rem;
    }

    .legend-dot {
      width: 10px;
      height: 10px;
      border-radius: var(--radius-pill);
    }

    .table-wrap {
      width: 100%;
      max-width: 100%;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .table-footer {
      margin-top: 10px;
    }

    .table-footer .ghost-button {
      width: 100%;
      justify-content: center;
      text-align: center;
      padding-block: 10px;
    }

    .two-col {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: 16px;
    }

    .wide-stack {
      display: grid;
      grid-template-columns: 1fr;
      gap: 16px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.92rem;
    }

    th, td {
      padding: 10px 8px;
      border-bottom: 1px solid var(--line);
      text-align: left;
      vertical-align: middle;
    }

    th {
      color: var(--muted);
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-weight: 700;
    }

    td.num {
      text-align: right;
      font-variant-numeric: tabular-nums;
      font-family: var(--font-mono);
    }

    .rank {
      color: var(--muted);
      width: 42px;
    }

    .leader {
      min-width: 180px;
    }

    .leader strong {
      display: block;
      font-size: 0.96rem;
      color: var(--text);
    }

    .leader span {
      display: block;
      margin-top: 4px;
      color: var(--muted);
      font-size: 0.82rem;
    }

    .bar-cell {
      min-width: 200px;
    }

    .bar-track {
      width: 100%;
      height: 8px;
      background: var(--track);
      border-radius: var(--radius-pill);
      overflow: hidden;
      margin-bottom: 6px;
    }

    .bar-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--accent), var(--accent-2));
      border-radius: var(--radius-pill);
    }

    .bar-meta {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      color: var(--muted);
      font-size: 0.8rem;
    }

    .tag-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 12px;
    }

    .tag {
      padding: 7px 10px;
      border: 1px solid var(--line);
      border-radius: var(--radius-pill);
      color: var(--muted);
      font-size: 0.82rem;
      background: var(--panel-subtle);
    }

    .ghost-button,
    .author-button {
      border: 1px solid var(--line-strong);
      background: var(--panel-subtle);
      color: var(--text);
      border-radius: var(--radius-control);
      padding: 8px 12px;
      font: inherit;
      cursor: pointer;
    }

    .ghost-button:hover,
    .author-button:hover,
    .author-button.active {
      background: var(--active-fill);
      border-color: var(--accent);
    }

    .hidden {
      display: none !important;
    }

    .detail-shell {
      display: grid;
      gap: 14px;
    }

    .people-grid {
      display: grid;
      grid-template-columns: minmax(280px, 0.36fr) minmax(0, 0.64fr);
      gap: 16px;
      align-items: start;
    }

    .people-grid > * {
      min-width: 0;
    }

    .person-list {
      display: grid;
      gap: 10px;
    }

    .person-card {
      width: 100%;
      min-width: 0;
      display: grid;
      gap: 8px;
      border: 1px solid var(--line);
      border-left: 3px solid transparent;
      border-radius: var(--radius-control);
      padding: 12px;
      background: var(--panel-subtle);
      color: var(--text);
      font: inherit;
      text-align: left;
      cursor: pointer;
    }

    .person-card:hover,
    .person-card.active {
      border-color: var(--line-strong);
      border-left-color: var(--accent);
      background: var(--theme-toggle-hover);
    }

    .person-card-header,
    .person-card-metrics,
    .profile-summary {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: baseline;
      min-width: 0;
    }

    .person-card-metrics,
    .profile-summary {
      flex-wrap: wrap;
    }

    .person-card strong {
      font-size: 1rem;
    }

    .person-card small,
    .profile-summary span {
      color: var(--muted);
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .person-card-metrics span {
      color: var(--muted);
      font-size: 0.82rem;
    }

    .person-profile {
      display: grid;
      gap: 14px;
      min-width: 0;
    }

    .person-profile > *,
    .detail-shell,
    .detail-grid,
    .profile-subgrid {
      min-width: 0;
      max-width: 100%;
    }

    .person-profile .detail-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .person-profile .chart-root {
      aspect-ratio: 16 / 5;
      min-height: 220px;
    }

    .person-profile .chart-root svg {
      min-height: 220px;
    }

    .profile-subgrid {
      display: grid;
      grid-template-columns: minmax(0, 1.35fr) minmax(0, 0.9fr) minmax(0, 0.75fr);
      gap: 14px;
    }

    .detail-tabs {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .detail-grid {
      display: grid;
      grid-template-columns: repeat(6, minmax(0, 1fr));
      gap: 10px;
    }

    .detail-card {
      border: 1px solid var(--line);
      border-radius: var(--radius-control);
      padding: 12px;
      background: var(--panel-subtle);
    }

    .detail-card strong {
      display: block;
      margin-bottom: 6px;
      color: var(--muted);
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .detail-card span {
      font-size: 1.1rem;
      font-weight: 700;
    }

    .state-list {
      display: grid;
      gap: 10px;
    }

    .state-row {
      display: grid;
      grid-template-columns: 160px minmax(0, 1fr) 70px;
      gap: 12px;
      align-items: center;
    }

    .state-track {
      height: 10px;
      background: var(--track);
      border-radius: var(--radius-pill);
      overflow: hidden;
    }

    .state-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--accent-3), var(--accent));
    }

    .small-note {
      color: var(--muted);
      font-size: 0.82rem;
    }

    .summary-strip,
    .support-grid,
    .reference-grid,
    .reference-stack {
      display: grid;
      gap: 12px;
    }

    .summary-strip {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      margin-bottom: 16px;
    }

    .summary-card,
    .support-card {
      padding: 14px 16px;
      min-width: 0;
    }

    .summary-label {
      display: block;
      margin-bottom: 8px;
      color: var(--muted);
      font-size: 0.72rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-weight: 700;
    }

    .summary-card strong,
    .support-card strong {
      display: block;
      margin-bottom: 6px;
      font-size: 1rem;
      font-family: var(--font-display);
    }

    .summary-card span,
    .support-card span,
    .control-note {
      color: var(--muted);
      line-height: 1.5;
      font-size: 0.86rem;
    }

    .support-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .control-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 12px;
    }

    .control-actions {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }

    .search-input {
      min-width: 220px;
      max-width: 100%;
      border: 1px solid var(--line-strong);
      background: var(--panel-subtle);
      color: var(--text);
      border-radius: var(--radius-control);
      padding: 9px 12px;
      font: inherit;
    }

    .search-input::placeholder {
      color: var(--muted);
    }

    .search-input:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    .reference-panel {
      display: grid;
      gap: 14px;
    }

    .reference-grid {
      grid-template-columns: 1fr;
    }

    .reference-stack {
      grid-template-columns: 1fr;
    }

    .disclosure {
      border: 1px solid var(--line);
      border-radius: var(--radius-control);
      background: var(--panel-subtle);
      overflow: hidden;
    }

    .disclosure > summary {
      list-style: none;
      cursor: pointer;
      padding: 14px 16px;
      font-weight: 700;
      font-family: var(--font-display);
      border-bottom: 1px solid transparent;
    }

    .disclosure[open] > summary {
      border-bottom-color: var(--line);
    }

    .disclosure > summary::-webkit-details-marker {
      display: none;
    }

    .disclosure > :not(summary) {
      padding: 14px 16px 16px;
    }

    .methodology-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
    }

    .tablet-hide {
      display: table-cell;
    }

    @media (max-width: 1320px) {
      .stats-grid,
      .detail-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }

    @media (max-width: 1180px) {
      .hero {
        grid-template-columns: 1fr;
      }

      .two-col,
      .chart-readout,
      .profile-subgrid,
      .support-grid,
      .summary-strip,
      .methodology-grid {
        grid-template-columns: 1fr;
      }

      .hero-meta {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 1080px) {
      .tablet-hide {
        display: none;
      }

      .chart-root {
        aspect-ratio: 16 / 7;
      }

      .person-profile .chart-root {
        aspect-ratio: 16 / 6;
      }
    }

    @media (max-width: 860px) {
      .people-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 720px) {
      body { padding: 14px 12px 24px; }

      .hero-panel,
      .insight-panel,
      .section-panel {
        padding: 14px;
      }

      .hero-head {
        flex-direction: column;
      }

      .theme-switch {
        width: 100%;
        justify-content: space-between;
      }

      .hero-meta {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .stats-grid,
      .summary-strip,
      .detail-grid,
      .person-profile .detail-grid {
        grid-template-columns: 1fr;
      }

      .control-actions {
        width: 100%;
        justify-content: stretch;
      }

      .search-input {
        width: 100%;
        min-width: 0;
      }

      .table-wrap {
        overflow-x: visible;
      }

      table,
      tbody,
      tr,
      td {
        display: block;
        width: 100%;
      }

      thead {
        display: none;
      }

      tr {
        margin-bottom: 12px;
        padding: 12px;
        border: 1px solid var(--line);
        border-radius: var(--radius-control);
        background: var(--panel-subtle);
      }

      td {
        padding: 7px 0;
        border-bottom: 1px solid var(--line-faint);
      }

      td:last-child {
        border-bottom: 0;
      }

      td::before {
        content: attr(data-label);
        display: block;
        margin-bottom: 4px;
        color: var(--muted);
        font-size: 0.7rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        font-weight: 700;
      }

      td.rank::before {
        content: "Rank";
      }

      .leader,
      .bar-cell,
      td.num {
        min-width: 0;
        text-align: left;
      }

      .bar-track {
        margin-top: 6px;
      }

      .state-row {
        grid-template-columns: 1fr;
      }

      .bar-cell {
        min-width: 0;
      }

      .section-nav {
        position: static;
      }

      .chart-root {
        aspect-ratio: 4 / 3;
        min-height: 240px;
        max-width: 100%;
        overflow: hidden;
      }

      .chart-root svg {
        min-height: 240px;
      }
    }

    @media (max-width: 360px) {
      .hero-meta {
        grid-template-columns: 1fr;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      html {
        scroll-behavior: auto;
      }

      .theme-switch-indicator,
      .theme-switch-button,
      .theme-switch-icon {
        transition: none;
      }
    }
  </style>
</head>
<body>
  <div class="shell">
    <section class="hero">
      <div class="panel hero-panel">
        <div class="hero-head">
          <div class="hero-copy">
            <p class="eyebrow">Engineering Productivity Leaderboard</p>
            <h1>{{ overview.org }} review and throughput board</h1>
            <p class="subtitle">
              Leaderboard view for the selected window. The page focuses on who shipped,
              who reviewed, where flow concentrated, and how review latency moved with PR
              size, with chart tabs for period and person-level inspection.
            </p>
          </div>
          <div class="theme-switch" role="group" aria-label="Color theme">
            <span class="theme-switch-indicator" aria-hidden="true"></span>
            <button type="button" class="theme-switch-button" data-theme-option="dark" aria-label="Dark theme" aria-pressed="false" title="Dark theme">
              <svg class="theme-switch-icon" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 1 0 9.8 9.8Z"></path>
              </svg>
            </button>
            <button type="button" class="theme-switch-button" data-theme-option="light" aria-label="Light theme" aria-pressed="false" title="Light theme">
              <svg class="theme-switch-icon" viewBox="0 0 24 24" aria-hidden="true">
                <circle cx="12" cy="12" r="4.1"></circle>
                <path d="M12 2.75v2.35"></path>
                <path d="M12 18.9v2.35"></path>
                <path d="M21.25 12h-2.35"></path>
                <path d="M5.1 12H2.75"></path>
                <path d="m18.55 5.45-1.66 1.66"></path>
                <path d="m7.11 16.89-1.66 1.66"></path>
                <path d="m18.55 18.55-1.66-1.66"></path>
                <path d="m7.11 7.11-1.66-1.66"></path>
              </svg>
            </button>
          </div>
        </div>
        <div class="hero-meta">
          <div class="meta-box">
            <span class="meta-label">Window</span>
            <span class="meta-value">{{ overview.since }} to {{ overview.until }}</span>
          </div>
          <div class="meta-box">
            <span class="meta-label">Open backlog risk</span>
            <span class="meta-value">{{ overview.stale_open_pull_requests | intfmt }} stale open PRs</span>
          </div>
          <div class="meta-box">
            <span class="meta-label">Review SLA</span>
            <span class="meta-value">{{ overview.review_sla_24h_pct | numfmt }}% within 24h</span>
          </div>
          <div class="meta-box">
            <span class="meta-label">Concentration risk</span>
            <span class="meta-value">Top 3 authors: {{ reference_summary.top3_author_share_pct | numfmt }}%</span>
          </div>
        </div>
      </div>
    </section>

    <section class="stats-grid">
      <article class="stat-card">
        <span class="stat-label">PR throughput</span>
        <div class="stat-value">{{ overview.pull_requests | intfmt }}</div>
        <div class="stat-subvalue">{{ overview.merged_pull_requests | intfmt }} merged / {{ overview.open_pull_requests | intfmt }} open</div>
      </article>
      <article class="stat-card">
        <span class="stat-label">Review coverage</span>
        <div class="stat-value">{{ overview.review_coverage_pct }}%</div>
        <div class="stat-subvalue">{{ overview.review_submissions | intfmt }} total review submissions</div>
      </article>
      <article class="stat-card">
        <span class="stat-label">Median first review</span>
        <div class="stat-value">{{ overview.median_first_review_hours | duration }}</div>
        <div class="stat-subvalue">from ready/request to first review</div>
      </article>
      <article class="stat-card">
        <span class="stat-label">Median merge time</span>
        <div class="stat-value">{{ overview.median_merge_hours | duration }}</div>
        <div class="stat-subvalue">from PR creation to merge</div>
      </article>
    </section>

    <section class="summary-strip">
      <article class="summary-card panel">
        <span class="summary-label">Changed lines</span>
        <strong>{{ overview.total_changed_lines | intfmt }}</strong>
        <span>{{ overview.average_changed_lines_per_pr | numfmt }} lines per PR</span>
      </article>
      <article class="summary-card panel">
        <span class="summary-label">Review capacity</span>
        <strong>{{ overview.unique_reviewers | intfmt }} reviewers</strong>
        <span>{{ overview.average_reviews_per_pr | numfmt }} reviews per PR</span>
      </article>
      <article class="summary-card panel">
        <span class="summary-label">Repo concentration</span>
        <strong>{{ reference_summary.top3_repository_share_pct | numfmt }}%</strong>
        <span>of PRs came from the top 3 repositories</span>
      </article>
      <article class="summary-card panel">
        <span class="summary-label">Method</span>
        <strong>{{ methodology.distribution_percentile }}th percentile cap</strong>
        <span>{{ methodology.anchor }} anchor, generated {{ methodology.generated_at[:10] }}</span>
      </article>
    </section>

    <nav class="section-nav" aria-label="Report sections">
      <a href="#trends">Trends</a>
      <a href="#people">People</a>
      <a href="#leaderboards">Leaderboards</a>
      <a href="#diagnostics">Diagnostics</a>
      <a href="#reference">Reference</a>
    </nav>

    <div class="section-grid">
      <section id="trends" class="panel section-panel chart-panel">
        <p class="section-kicker">Trend charts</p>
        <h2>Weekly and monthly movement, graphed</h2>
        <p class="section-copy">Primary trend surface for throughput, code volume, and review speed. Dense weekly/monthly tables live in the reference section below.</p>
        <div class="two-col">
          <div class="tab-strip" id="trend-metric-tabs">
            <button type="button" class="tab-button active" data-metric="pull_requests" aria-selected="true">PR throughput</button>
            <button type="button" class="tab-button" data-metric="changed_lines" aria-selected="false">Changed lines</button>
            <button type="button" class="tab-button" data-metric="median_first_review_hours" aria-selected="false">First review</button>
            <button type="button" class="tab-button" data-metric="median_merge_hours" aria-selected="false">Merge time</button>
          </div>
          <div class="tab-strip" id="trend-grain-tabs">
            <button type="button" class="tab-button active" data-grain="weekly" aria-selected="true">Weekly</button>
            <button type="button" class="tab-button" data-grain="monthly" aria-selected="false">Monthly</button>
          </div>
        </div>
        <div class="chart-title">
          <span id="trend-chart-title">PR throughput by week</span>
          <div class="chart-legend">
            <span class="legend-chip"><span class="legend-dot" style="background: var(--accent)"></span>Selected metric</span>
          </div>
        </div>
        <div id="trend-chart-readout" class="chart-readout"></div>
        <div id="trend-chart-root" class="chart-root"></div>
        <div class="support-grid">
          <article class="support-card">
            <strong>Interpretation</strong>
            <span>Use the chart for movement. Full weekly and monthly tables are intentionally collapsed into reference to keep the main flow shorter.</span>
          </article>
          <article class="support-card">
            <strong>Concentration</strong>
            <span>Top 3 authors account for {{ reference_summary.top3_author_share_pct | numfmt }}% of authored PRs in this window.</span>
          </article>
          <article class="support-card">
            <strong>Backlog</strong>
            <span>{{ overview.stale_open_pull_requests | intfmt }} open PRs are older than 72 hours at window end.</span>
          </article>
        </div>
      </section>

      <section id="people" class="panel section-panel">
        <p class="section-kicker">People command center</p>
        <h2>One person, delivery and review context together</h2>
        <p class="section-copy">Use the roster for the top 12 by default. Search jumps directly to any author without forcing the main page to render a massive always-open ledger.</p>
        <div class="control-row">
          <span class="control-note">Top 12 cover {{ reference_summary.author_roster_coverage_pct | numfmt }}% of authored PR flow.</span>
          <div class="control-actions">
            <input id="author-roster-search" class="search-input" type="search" placeholder="Find a person" aria-label="Find a person">
          </div>
        </div>
        <div class="people-grid">
          <div>
            <p class="section-kicker">Delivery roster</p>
            <div class="person-list">
              {% for row in authors_roster_top %}
              <button
                type="button"
                class="author-button person-card{% if default_author == row.author_login %} active{% endif %}"
                data-author="{{ row.author_login }}"
                data-author-surface="roster"
                data-overflow="false"
                aria-pressed="{% if default_author == row.author_login %}true{% else %}false{% endif %}"
              >
                <span class="person-card-header">
                  <strong>{{ row.author_login }}</strong>
                  <small>#{{ loop.index }}</small>
                </span>
                <span class="person-card-metrics">
                  <span>{{ row.pull_requests | intfmt }} PRs</span>
                  <span>{{ row.changed_lines | intfmt }} lines</span>
                  <span>{{ row.median_first_review_hours | duration }} first review</span>
                </span>
              </button>
              {% endfor %}
              {% for row in authors_roster_rest %}
              <button
                type="button"
                class="author-button person-card hidden roster-overflow{% if default_author == row.author_login %} active{% endif %}"
                data-author="{{ row.author_login }}"
                data-author-surface="roster"
                data-overflow="true"
                aria-pressed="{% if default_author == row.author_login %}true{% else %}false{% endif %}"
              >
                <span class="person-card-header">
                  <strong>{{ row.author_login }}</strong>
                  <small>#{{ loop.index + authors_roster_top|length }}</small>
                </span>
                <span class="person-card-metrics">
                  <span>{{ row.pull_requests | intfmt }} PRs</span>
                  <span>{{ row.changed_lines | intfmt }} lines</span>
                  <span>{{ row.median_first_review_hours | duration }} first review</span>
                </span>
              </button>
              {% endfor %}
            </div>
            {% if authors_roster_rest %}
            <div class="table-footer">
              <button type="button" id="author-roster-toggle" class="ghost-button" aria-expanded="false">
                Show {{ authors_roster_rest|length }} more people
              </button>
            </div>
            {% endif %}
          </div>
          <div id="author-detail" class="person-profile" tabindex="-1">
            <div class="profile-summary">
              <div>
                <p class="section-kicker">Selected profile</p>
                <h2 id="author-detail-title">Person detail</h2>
              </div>
              <span>Author + reviewer signals</span>
            </div>
            <div class="detail-tabs" id="author-detail-view-tabs">
              <button type="button" class="tab-button active" data-author-view="timeline" aria-selected="true">Timeline</button>
              <button type="button" class="tab-button" data-author-view="mix" aria-selected="false">Size mix</button>
            </div>
            <div class="two-col">
              <div class="detail-tabs" id="author-detail-metric-tabs">
                <button type="button" class="tab-button active" data-author-metric="pull_requests" aria-selected="true">Throughput</button>
                <button type="button" class="tab-button" data-author-metric="changed_lines" aria-selected="false">Changed lines</button>
                <button type="button" class="tab-button" data-author-metric="median_first_review_hours" aria-selected="false">Review speed</button>
                <button type="button" class="tab-button" data-author-metric="median_merge_hours" aria-selected="false">Merge speed</button>
              </div>
              <div class="detail-tabs" id="author-detail-grain-tabs">
                <button type="button" class="tab-button active" data-author-grain="weekly" aria-selected="true">Weekly</button>
                <button type="button" class="tab-button" data-author-grain="monthly" aria-selected="false">Monthly</button>
              </div>
            </div>
            <div class="chart-title">
              <span id="author-chart-title">Author chart</span>
              <div class="chart-legend">
                <span class="legend-chip"><span class="legend-dot" style="background: var(--accent-2)"></span>Selected person</span>
              </div>
            </div>
            <div id="author-chart-readout" class="chart-readout"></div>
            <div id="author-chart-root" class="chart-root"></div>
            <div id="author-detail-root" class="detail-shell"></div>
          </div>
        </div>
      </section>

      <section id="leaderboards" class="panel section-panel">
        <p class="section-kicker">Team leaderboards</p>
        <h2>Compare reviewers and repositories without opening the full reference layer</h2>
        <p class="section-copy">Top 10 lists stay visible by default. Long tails are hidden behind explicit expansion so the main dashboard remains scannable as the org grows.</p>
        <div class="wide-stack">
        <article id="reviewers">
          <p class="section-kicker">Reviewer leaderboard</p>
          <h2>Who carried review load</h2>
          <p class="section-copy">Top 10 reviewers cover {{ reference_summary.reviewers_top_coverage_pct | numfmt }}% of reviewed PR touches.</p>
          <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th class="rank">#</th>
                <th>Reviewer</th>
                <th class="num">PRs reviewed</th>
                <th class="num">Submissions</th>
                <th class="num">Approvals</th>
                <th class="num tablet-hide">Changes requested</th>
                <th class="num tablet-hide">Comments</th>
                <th class="num tablet-hide">Authors supported</th>
              </tr>
            </thead>
            <tbody>
              {% for row in reviewers_top %}
              <tr>
                <td class="rank" data-label="Rank">{{ loop.index }}</td>
                <td class="leader" data-label="Reviewer">
                  <strong>{{ row.reviewer_login }}</strong>
                  <span>{{ row.pull_requests_reviewed | intfmt }} PRs touched</span>
                </td>
                <td class="num" data-label="PRs reviewed">{{ row.pull_requests_reviewed | intfmt }}</td>
                <td class="num" data-label="Submissions">{{ row.review_submissions | intfmt }}</td>
                <td class="num" data-label="Approvals">{{ row.approvals | intfmt }}</td>
                <td class="num tablet-hide" data-label="Changes requested">{{ row.changes_requested | intfmt }}</td>
                <td class="num tablet-hide" data-label="Comments">{{ row.comments | intfmt }}</td>
                <td class="num tablet-hide" data-label="Authors supported">{{ row.authors_supported | intfmt }}</td>
              </tr>
              {% endfor %}
            </tbody>
            {% if reviewers_rest %}
            <tbody id="reviewer-extra" class="hidden">
              {% for row in reviewers_rest %}
              <tr>
                <td class="rank" data-label="Rank">{{ loop.index + 10 }}</td>
                <td class="leader" data-label="Reviewer">
                  <strong>{{ row.reviewer_login }}</strong>
                  <span>{{ row.pull_requests_reviewed | intfmt }} PRs touched</span>
                </td>
                <td class="num" data-label="PRs reviewed">{{ row.pull_requests_reviewed | intfmt }}</td>
                <td class="num" data-label="Submissions">{{ row.review_submissions | intfmt }}</td>
                <td class="num" data-label="Approvals">{{ row.approvals | intfmt }}</td>
                <td class="num tablet-hide" data-label="Changes requested">{{ row.changes_requested | intfmt }}</td>
                <td class="num tablet-hide" data-label="Comments">{{ row.comments | intfmt }}</td>
                <td class="num tablet-hide" data-label="Authors supported">{{ row.authors_supported | intfmt }}</td>
              </tr>
              {% endfor %}
            </tbody>
            {% endif %}
          </table>
          </div>
          {% if reviewers_rest %}
          <div class="table-footer">
            <button type="button" id="reviewer-toggle" class="ghost-button" aria-expanded="false">
              Show {{ reviewers_rest|length }} more reviewers
            </button>
          </div>
          {% endif %}
        </article>

        <article id="repositories">
          <p class="section-kicker">Repository leaderboard</p>
          <h2>Where throughput concentrated</h2>
          <p class="section-copy">Top 10 repositories cover {{ reference_summary.repositories_top_coverage_pct | numfmt }}% of org PR throughput.</p>
          <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th class="rank">#</th>
                <th>Repository</th>
                <th>PR share</th>
                <th class="num">PRs</th>
                <th class="num">Merged</th>
                <th class="num tablet-hide">Open</th>
                <th class="num tablet-hide">Authors</th>
                <th class="num tablet-hide">Reviews / PR</th>
                <th class="num">Median first review</th>
              </tr>
            </thead>
            <tbody>
              {% for row in repositories_top %}
              <tr>
                <td class="rank" data-label="Rank">{{ loop.index }}</td>
                <td class="leader" data-label="Repository">
                  <strong>{{ row.repository_full_name }}</strong>
                  <span>{{ row.changed_lines | intfmt }} changed lines</span>
                </td>
                <td class="bar-cell" data-label="PR share">
                  <div class="bar-track">
                    <div class="bar-fill" style="width: {{ row.share_of_prs_pct or 0 }}%"></div>
                  </div>
                  <div class="bar-meta">
                    <span>{{ row.share_of_prs_pct }}%</span>
                    <span>{{ row.changed_lines | intfmt }} lines</span>
                  </div>
                </td>
                <td class="num" data-label="PRs">{{ row.pull_requests | intfmt }}</td>
                <td class="num" data-label="Merged">{{ row.merged_pull_requests | intfmt }}</td>
                <td class="num tablet-hide" data-label="Open">{{ row.open_pull_requests | intfmt }}</td>
                <td class="num tablet-hide" data-label="Authors">{{ row.authors | intfmt }}</td>
                <td class="num tablet-hide" data-label="Reviews / PR">{{ row.average_reviews_per_pr | numfmt }}</td>
                <td class="num" data-label="Median first review">{{ row.median_first_review_hours | duration }}</td>
              </tr>
              {% endfor %}
            </tbody>
            {% if repositories_rest %}
            <tbody id="repository-extra" class="hidden">
              {% for row in repositories_rest %}
              <tr>
                <td class="rank" data-label="Rank">{{ loop.index + 10 }}</td>
                <td class="leader" data-label="Repository">
                  <strong>{{ row.repository_full_name }}</strong>
                  <span>{{ row.changed_lines | intfmt }} changed lines</span>
                </td>
                <td class="bar-cell" data-label="PR share">
                  <div class="bar-track">
                    <div class="bar-fill" style="width: {{ row.share_of_prs_pct or 0 }}%"></div>
                  </div>
                  <div class="bar-meta">
                    <span>{{ row.share_of_prs_pct }}%</span>
                    <span>{{ row.changed_lines | intfmt }} lines</span>
                  </div>
                </td>
                <td class="num" data-label="PRs">{{ row.pull_requests | intfmt }}</td>
                <td class="num" data-label="Merged">{{ row.merged_pull_requests | intfmt }}</td>
                <td class="num tablet-hide" data-label="Open">{{ row.open_pull_requests | intfmt }}</td>
                <td class="num tablet-hide" data-label="Authors">{{ row.authors | intfmt }}</td>
                <td class="num tablet-hide" data-label="Reviews / PR">{{ row.average_reviews_per_pr | numfmt }}</td>
                <td class="num" data-label="Median first review">{{ row.median_first_review_hours | duration }}</td>
              </tr>
              {% endfor %}
            </tbody>
            {% endif %}
          </table>
          </div>
          {% if repositories_rest %}
          <div class="table-footer">
            <button type="button" id="repository-toggle" class="ghost-button" aria-expanded="false">
              Show {{ repositories_rest|length }} more repositories
            </button>
          </div>
          {% endif %}
        </article>
        </div>
      </section>

      <section id="diagnostics" class="panel section-panel">
        <p class="section-kicker">Review latency by PR size</p>
        <h2>How bigger changes slowed flow</h2>
        <p class="section-copy">{{ size_diagnostic.headline }} {{ size_diagnostic.supporting }}</p>
        <div class="summary-strip">
          <article class="summary-card panel">
            <span class="summary-label">Latency and quality</span>
            <strong>{{ overview.review_sla_24h_pct | numfmt }}% within 24h</strong>
            <span>PRs that received a first review within one day of becoming reviewable.</span>
          </article>
          <article class="summary-card panel">
            <span class="summary-label">Review depth</span>
            <strong>{{ overview.average_reviews_per_pr | numfmt }} reviews / PR</strong>
            <span>{{ overview.review_coverage_pct | numfmt }}% of PRs received at least one review.</span>
          </article>
          <article class="summary-card panel">
            <span class="summary-label">Backlog risk</span>
            <strong>{{ overview.stale_open_pull_requests | intfmt }} stale open PRs</strong>
            <span>Open pull requests older than 72 hours at the end of the reporting window.</span>
          </article>
          <article class="summary-card panel">
            <span class="summary-label">Median response</span>
            <strong>{{ overview.median_first_review_hours | duration }}</strong>
            <span>{{ overview.median_merge_hours | duration }} median merge time across the window.</span>
          </article>
        </div>
        <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Size</th>
              <th class="num">PRs</th>
              <th class="num">Median lines</th>
              <th class="num">Median first review</th>
              <th class="num">Median merge</th>
              <th class="num tablet-hide">Reviews / PR</th>
            </tr>
          </thead>
          <tbody>
            {% for row in size_buckets %}
            <tr>
              <td class="leader" data-label="Size">
                <strong>{{ row.bucket }}</strong>
                <span>Size bucket</span>
              </td>
              <td class="num" data-label="PRs">{{ row.pull_requests | intfmt }}</td>
              <td class="num" data-label="Median lines">{{ row.median_changed_lines | numfmt }}</td>
              <td class="num" data-label="Median first review">{{ row.median_first_review_hours | duration }}</td>
              <td class="num" data-label="Median merge">{{ row.median_merge_hours | duration }}</td>
              <td class="num tablet-hide" data-label="Reviews / PR">{{ row.average_reviews_per_pr | numfmt }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
        </div>
        <div class="tag-row">
          <span class="tag">XS: up to 100 changed lines</span>
          <span class="tag">S: 101-400</span>
          <span class="tag">M: 401-1000</span>
          <span class="tag">L: 1001-3000</span>
          <span class="tag">XL: 3001+</span>
        </div>
      </section>

      <section id="reference" class="panel section-panel reference-panel">
        <p class="section-kicker">Reference</p>
        <h2>Dense tables and methodology, on demand</h2>
        <p class="section-copy">These sections stay collapsed by default so large org windows do not force the main dashboard into a long scroll-only document.</p>
        <div class="reference-grid">
          <details class="disclosure" open>
            <summary>Trend tables</summary>
            <div class="reference-stack">
              <article>
                <div class="control-row">
                  <span class="control-note">Recent 12 weeks shown first. {{ reference_summary.weekly_hidden_count | intfmt }} older weekly rows are hidden until expanded.</span>
                </div>
                <div class="table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th>Week</th>
                      <th class="num">PRs</th>
                      <th class="num">Merged</th>
                      <th class="num tablet-hide">Open</th>
                      <th class="num">Changed lines</th>
                      <th class="num tablet-hide">Reviews / PR</th>
                      <th class="num">Median first review</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for row in weekly_trends_recent %}
                    <tr>
                      <td class="leader" data-label="Week">
                        <strong>{{ row.period_key }}</strong>
                        <span>created_at basis</span>
                      </td>
                      <td class="num" data-label="PRs">{{ row.pull_requests | intfmt }}</td>
                      <td class="num" data-label="Merged">{{ row.merged_pull_requests | intfmt }}</td>
                      <td class="num tablet-hide" data-label="Open">{{ row.open_pull_requests | intfmt }}</td>
                      <td class="num" data-label="Changed lines">{{ row.changed_lines | intfmt }}</td>
                      <td class="num tablet-hide" data-label="Reviews / PR">{{ row.average_reviews_per_pr | numfmt }}</td>
                      <td class="num" data-label="Median first review">{{ row.median_first_review_hours | duration }}</td>
                    </tr>
                    {% endfor %}
                  </tbody>
                  {% if weekly_trends_older %}
                  <tbody id="weekly-trend-extra" class="hidden">
                    {% for row in weekly_trends_older %}
                    <tr>
                      <td class="leader" data-label="Week">
                        <strong>{{ row.period_key }}</strong>
                        <span>created_at basis</span>
                      </td>
                      <td class="num" data-label="PRs">{{ row.pull_requests | intfmt }}</td>
                      <td class="num" data-label="Merged">{{ row.merged_pull_requests | intfmt }}</td>
                      <td class="num tablet-hide" data-label="Open">{{ row.open_pull_requests | intfmt }}</td>
                      <td class="num" data-label="Changed lines">{{ row.changed_lines | intfmt }}</td>
                      <td class="num tablet-hide" data-label="Reviews / PR">{{ row.average_reviews_per_pr | numfmt }}</td>
                      <td class="num" data-label="Median first review">{{ row.median_first_review_hours | duration }}</td>
                    </tr>
                    {% endfor %}
                  </tbody>
                  {% endif %}
                </table>
                </div>
                {% if weekly_trends_older %}
                <div class="table-footer">
                  <button type="button" id="weekly-trend-toggle" class="ghost-button" aria-expanded="false">
                    Show older weekly rows
                  </button>
                </div>
                {% endif %}
              </article>

              <article>
                <div class="control-row">
                  <span class="control-note">Recent 6 months shown first. {{ reference_summary.monthly_hidden_count | intfmt }} older monthly rows are hidden until expanded.</span>
                </div>
                <div class="table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th>Month</th>
                      <th class="num">PRs</th>
                      <th class="num">Merged</th>
                      <th class="num tablet-hide">Open</th>
                      <th class="num">Changed lines</th>
                      <th class="num">Median first review</th>
                      <th class="num tablet-hide">Median merge</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for row in monthly_trends_recent %}
                    <tr>
                      <td class="leader" data-label="Month">
                        <strong>{{ row.period_key }}</strong>
                        <span>created_at basis</span>
                      </td>
                      <td class="num" data-label="PRs">{{ row.pull_requests | intfmt }}</td>
                      <td class="num" data-label="Merged">{{ row.merged_pull_requests | intfmt }}</td>
                      <td class="num tablet-hide" data-label="Open">{{ row.open_pull_requests | intfmt }}</td>
                      <td class="num" data-label="Changed lines">{{ row.changed_lines | intfmt }}</td>
                      <td class="num" data-label="Median first review">{{ row.median_first_review_hours | duration }}</td>
                      <td class="num tablet-hide" data-label="Median merge">{{ row.median_merge_hours | duration }}</td>
                    </tr>
                    {% endfor %}
                  </tbody>
                  {% if monthly_trends_older %}
                  <tbody id="monthly-trend-extra" class="hidden">
                    {% for row in monthly_trends_older %}
                    <tr>
                      <td class="leader" data-label="Month">
                        <strong>{{ row.period_key }}</strong>
                        <span>created_at basis</span>
                      </td>
                      <td class="num" data-label="PRs">{{ row.pull_requests | intfmt }}</td>
                      <td class="num" data-label="Merged">{{ row.merged_pull_requests | intfmt }}</td>
                      <td class="num tablet-hide" data-label="Open">{{ row.open_pull_requests | intfmt }}</td>
                      <td class="num" data-label="Changed lines">{{ row.changed_lines | intfmt }}</td>
                      <td class="num" data-label="Median first review">{{ row.median_first_review_hours | duration }}</td>
                      <td class="num tablet-hide" data-label="Median merge">{{ row.median_merge_hours | duration }}</td>
                    </tr>
                    {% endfor %}
                  </tbody>
                  {% endif %}
                </table>
                </div>
                {% if monthly_trends_older %}
                <div class="table-footer">
                  <button type="button" id="monthly-trend-toggle" class="ghost-button" aria-expanded="false">
                    Show older monthly rows
                  </button>
                </div>
                {% endif %}
              </article>
            </div>
          </details>

          <details class="disclosure">
            <summary>Author ledger</summary>
            <div class="control-row">
              <span class="control-note">Dense comparison table. Top 12 already cover {{ reference_summary.author_roster_coverage_pct | numfmt }}% of authored PR flow in the main explorer.</span>
            </div>
            <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th class="rank">#</th>
                  <th>Author</th>
                  <th>PR share</th>
                  <th class="num">PRs</th>
                  <th class="num">Merged</th>
                  <th class="num tablet-hide">Open</th>
                  <th class="num">Changed lines</th>
                  <th class="num tablet-hide">Commits</th>
                  <th class="num tablet-hide">Reviews / PR</th>
