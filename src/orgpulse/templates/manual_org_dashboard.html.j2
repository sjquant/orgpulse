                <div class="state-fill" style="width: {{ row.share_pct or 0 }}%"></div>
              </div>
              <div class="num">{{ row.share_pct | numfmt }}%</div>
            </div>
            {% endfor %}
          </div>
          <p class="table-footnote">
            Most of the review load in this window came from comment-only reviews, with
            approvals and change requests making up the remainder. This split is useful
            when you want to distinguish coordination overhead from formal gatekeeping.
          </p>
        </article>
